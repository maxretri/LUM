<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="600" viewBox="0 0 1200 600">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#F5F0EB"/>
      <stop offset="100%" stop-color="#E8E0D5"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="600" fill="url(#bg)"/>
  <!-- Car silhouette placeholder -->
  <rect x="200" y="320" width="800" height="10" fill="#C8B49A" rx="5" opacity="0.4"/>
  <ellipse cx="350" cy="330" rx="60" ry="15" fill="#2A3C2E" opacity="0.3"/>
  <ellipse cx="850" cy="330" rx="60" ry="15" fill="#2A3C2E" opacity="0.3"/>
  <!-- Body -->
  <path d="M180 330 Q200 250 350 230 Q500 210 600 220 Q750 210 900 230 Q1020 250 1040 330 Z" fill="#4A5C4E" stroke="#2A3C2E" stroke-width="2"/>
  <!-- Roof -->
  <path d="M380 230 Q450 170 600 160 Q750 170 820 230 Z" fill="#4A5C4E" stroke="#2A3C2E" stroke-width="1.5"/>
  <!-- Windows -->
  <path d="M400 228 Q450 175 600 165 Q720 175 810 228 Z" fill="#B8D4E8" opacity="0.6"/>
</svg>
