<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="900" viewBox="0 0 1920 900">
  <defs>
    <linearGradient id="road" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1a2030"/>
      <stop offset="100%" stop-color="#0a1020"/>
    </linearGradient>
    <linearGradient id="sky2" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#2a3545"/>
      <stop offset="100%" stop-color="#4a5060"/>
    </linearGradient>
  </defs>
  <rect width="1920" height="900" fill="url(#sky2)"/>
  <rect y="600" width="1920" height="300" fill="url(#road)"/>
  <!-- Road lines -->
  <line x1="960" y1="650" x2="960" y2="900" stroke="#F5F0EB" stroke-width="3" stroke-dasharray="40 20" opacity="0.5"/>
  <!-- Mountains -->
  <polygon points="0,600 300,300 600,600" fill="#1a2530" opacity="0.8"/>
  <polygon points="400,600 700,250 1000,600" fill="#1e2a38" opacity="0.7"/>
  <polygon points="900,600 1200,200 1500,600" fill="#1a2530" opacity="0.8"/>
  <polygon points="1300,600 1600,320 1920,600" fill="#1e2a38" opacity="0.7"/>
</svg>
